#!/usr/bin/env bash

set -uo pipefail

for cmd in rg fzf bat mktemp; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf 'rgf: missing required command %q\n' "$cmd" >&2
    exit 1
  fi
done

INITIAL_QUERY="${*:-}"
export TEMP="$(mktemp)"
trap 'rm -f "$TEMP"' EXIT

TRANSFORMER='
  rg_pat={q:1}      # The first word is passed to ripgrep
  fzf_pat={q:2..}   # The rest are passed to fzf
  if ! [[ -r "$TEMP" ]] || [[ $rg_pat != $(cat "$TEMP") ]]; then
    echo "$rg_pat" > "$TEMP"
    printf "reload:sleep 0.1; rg --follow --column --line-number --no-heading --color=always --smart-case %q || true" "$rg_pat"
  fi
  echo "+search:$fzf_pat"
'

fzf --ansi --disabled --query "$INITIAL_QUERY" \
    --with-shell 'bash -c' \
    --bind "start,change:transform:$TRANSFORMER" \
    --color "hl:-1:underline,hl+:-1:underline:reverse" \
    --delimiter : \
    --preview 'bat --color=always {1} --highlight-line {2}' \
    --preview-window 'up,60%,border-line,+{2}+3/3,~3' \
    --bind 'enter:become(nvim {1} +{2})'
