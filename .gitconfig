[user]
	name = mfkd
	email = mattkfd@gmail.com
[alias]
        co = checkout
        br = branch
        ci = commit
        st = status
        r = rebase
        f = fetch

[url "ssh://git@github.com/"]
        insteadOf = https://github.com/
[include]
	path = ~/.config/git/delta.gitconfig
[core]
	editor = nvim
	pager = delta
[gpg]
	format = ssh
